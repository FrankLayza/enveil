# ---- Frontend (VITE_ prefix = exposed to the browser bundle) ----

# Sepolia RPC endpoint (Alchemy/Infura recommended for demo stability)
VITE_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# ERC-7984 confidential token to distribute (our mock-token deploy address,
# or an official Zama cTokenMock once available)
VITE_MOCK_TOKEN_ADDRESS=0x...

# Optional: pin the TokenOps airdrop factory (normally auto-resolved by the SDK)
VITE_AIRDROP_FACTORY_ADDRESS=

# ---- Headless pipeline script only (NOT exposed to the browser) ----

# Same RPC, without the VITE_ prefix, for scripts/pipeline.ts
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# Test wallets for the end-to-end pipeline (Sepolia test keys ONLY — never real funds)
ADMIN_PRIVATE_KEY=0xadmin_test_key
RECIPIENT_PRIVATE_KEY=0xrecipient_test_key
