# Deployer wallet private key (NO 0x prefix issues — include the 0x). NEVER commit the real .env.
PRIVATE_KEY=0xyour_sepolia_test_wallet_private_key

# Sepolia RPC (Alchemy/Infura recommended for stability during demo recording)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key

# For `hardhat verify`
ETHERSCAN_API_KEY=your_etherscan_key

# Set after deploy, used by faucet.ts
MOCK_TOKEN_ADDRESS=
